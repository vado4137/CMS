// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Auth.js Models ---
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  isSuperAdmin  Boolean @default(false)
  accounts      Account[]
  sessions      Session[]
  memberships   Member[]
}

// --- Multi-Tenancy Models ---
enum FactionType {
  POLICE
  MEDICAL
  FIRE
  GOVERNMENT
  NEUTRAL
}

model Faction {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  type        FactionType @default(NEUTRAL) // <--- NEU
  description String?
  logoUrl     String?

  members     Member[]
  ranks       Rank[]
  
  // Verknüpfung zum CMS-Teil
  landingPage LandingPage? // <--- Vorbereitung für Schritt 3
  isRecruiting Boolean @default(false)

  // --- NEU: Diese Felder fehlten für die Gegenrelation ---
  departments Department[]
  locations   Location[]
  auditLogs   AuditLog[]
  trainings    Training[]
  trainingTypes    TrainingType[]
  trainingRequests TrainingRequest[]
}

model LandingPage {
  id          String   @id @default(cuid())
  factionId   String   @unique
  faction     Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  
  contentJson Json     @default("[]") // Hier liegen die CMS-Blöcke
  published   Boolean  @default(false)
  
  updatedAt   DateTime @updatedAt
}

model Member {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  factionId     String
  faction       Faction  @relation(fields: [factionId], references: [id])
  rankId        String
  rank          Rank     @relation(fields: [rankId], references: [id])
  instructorRequests TrainingRequest[] @relation("Instructor")
  authorizedTrainings TrainingType[] @relation("AuthorizedInstructors")


  // IC-Daten (Die Person im Spiel)
  firstName     String   // Max
  lastName      String   // Mustermann
  badgeNumber   Int?     // Dienstnummer (z.B. 42)
  phoneNumber   String?  // IC-Handynummer
  dateOfBirth   DateTime? 
  avatarUrl     String?  // Ein spezielles IC-Foto (getrennt vom Discord-Avatar)
  notes        String?      @db.Text
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  trainings    Training[]
  absences    Absence[]
  participatedTrainings TrainingRequest[] @relation("TrainingStudents")


  // --- NEU: Gegenstück für die Abteilungen ---
  departments   Department[]

  @@unique([userId, factionId])
}

model Rank {
  id          String   @id @default(cuid())
  name        String   // z.B. "Officer I", "Chief of Police"
  level       Int      // Für die Hierarchie (0-10)
  imageUrl    String?  // Pfad zum Abzeichen/Badge-Icon
  
  factionId   String
  faction     Faction  @relation(fields: [factionId], references: [id])
  
  permissions Json     @default("{}")
  members     Member[]

  @@unique([factionId, level])
}

model Department {
  id        String   @id @default(cuid())
  name      String
  shortName String?  
  factionId String
  faction   Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  members   Member[] // Mitglieder können Abteilungen zugewiesen werden
}

model Location {
  id        String   @id @default(cuid())
  name      String   
  factionId String
  faction   Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  members   Member[]
}

model AuditLog {
  id          String   @id @default(cuid())
  factionId   String
  faction     Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  memberId    String   // Der betroffene Officer 
  actorId     String   // Der ausführende Chief/Admin 
  action      String   // z.B. "RANK_UPDATE", "DEPT_ASSIGN" 
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())
}

model Training {
  id          String   @id @default(cuid())
  name        String
  shortName   String?  // z.B. "AGT" für Atemschutzgeräteträger
  description String?  @db.Text
  
  factionId   String
  faction     Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  
  members     Member[] // Many-to-Many: Ein Member kann viele Ausbildungen haben
  
  createdAt   DateTime @default(now())
}

model Absence {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  reason      String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([memberId])
}

enum TrainingStatus {
  OFFEN
  PLANNING
  PENDING
  FINISH
  DNF
}

model TrainingType {
  id          String            @id @default(cuid())
  name        String
  description String?           @db.Text
  factionId   String
  faction     Faction           @relation(fields: [factionId], references: [id])
  requests    TrainingRequest[]
  authorizedInstructors Member[] @relation("AuthorizedInstructors")
}

model TrainingRequest {
  id            String         @id @default(cuid())
  status        TrainingStatus @default(OFFEN)
  
  // Der Schüler
  students      Member[]       @relation("TrainingStudents")
  
  // Der Ausbilder (optional, bis angenommen)
  instructorId  String?
  instructor    Member?        @relation("Instructor", fields: [instructorId], references: [id])
  
  typeId        String
  trainingType  TrainingType   @relation(fields: [typeId], references: [id])
  
  factionId     String
  faction       Faction        @relation(fields: [factionId], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  scheduledDate DateTime?
}